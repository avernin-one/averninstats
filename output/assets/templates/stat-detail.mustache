<div class="stat-detail">
  <h2>{{title}}</h2>
  {{#sections}}
  <section class="stat-section">
    <h3>{{label}}</h3>
    <table class="score-table">
      <thead><tr><th>#</th><th>Player</th><th>Count</th></tr></thead>
      <tbody>
        {{#entries}}
        <tr>
          <td class="rank">{{rank}}</td>
          <td class="player-cell">
            <a href="#/player/{{name}}" class="player-link">
              <img src="{{headImg}}" alt="{{name}}" class="head-img" onerror="this.style.display='none'">
              {{name}}
            </a>
          </td>
          <td class="score">{{displayValue}}</td>
        </tr>
        {{/entries}}
      </tbody>
    </table>
  </section>
  {{/sections}}
</div>
